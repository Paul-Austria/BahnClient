    List<BlockArea> Blocks = new List<BlockArea>();
    List<SensorPoint> Points = new List<SensorPoint>();

    // Inputs
    string newBlockName = ""; string newBlockTopic = "esp32_1"; int newBlockPinA; int newBlockPinB;
    string newPointName = ""; string newPointTopic = "esp32_1"; int newPointPin;

    protected override void OnInitialized()
    {
        // Mock Data
        Blocks.Add(new BlockArea { ID = 1, Name = "Main Line East", ControllerTopic = "esp32_main", PinA = 12, PinB = 14, MagnetCount = 1, IsOccupied = true });
        Blocks.Add(new BlockArea { ID = 2, Name = "Siding 1", ControllerTopic = "esp32_yard", PinA = 27, PinB = 26, MagnetCount = 0, IsOccupied = false });
        Points.Add(new SensorPoint { ID = 1, Name = "Station Halt", ControllerTopic = "esp32_main", Pin = 33, IsTriggered = false });
    }

    void AddBlock()
    {
        if (!string.IsNullOrWhiteSpace(newBlockName))
        {
            int nextId = Blocks.Any() ? Blocks.Max(b => b.ID) + 1 : 1;
            var b = new BlockArea { ID = nextId, Name = newBlockName, ControllerTopic = newBlockTopic, PinA = newBlockPinA, PinB = newBlockPinB };
            Blocks.Add(b);

            // MQTT Command: To specific controller topic
            var payload = new { id = b.ID, name = b.Name, A = b.PinA, B = b.PinB };
            string topic = $"{b.ControllerTopic}/control/add_block";
            // MqttClient.Publish(topic, json);

            newBlockName = "";
        }
    }

    void ResetBlock(BlockArea b)
    {
        b.MagnetCount = 0; b.IsOccupied = false;
        string topic = $"{b.ControllerTopic}/control/reset_block";
        // MqttClient.Publish(topic, payload);
    }

    void AddPoint()
    {
        int nextId = Points.Any() ? Points.Max(p => p.ID) + 1 : 1;
        var p = new SensorPoint { ID = nextId, Name = newPointName, ControllerTopic = newPointTopic, Pin = newPointPin };
        Points.Add(p);
        // MQTT Publish...
    }

    void ResetPoint(SensorPoint p) { p.IsTriggered = false; }
    public void Dispose() { }
}