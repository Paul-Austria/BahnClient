@page "/traincockpit"
@using System.Collections.Generic;
@using System.Linq;

<PageTitle>Train Cockpit</PageTitle>

<div class="container-fluid vh-100 py-3" style="background-color: #f4f6f9;">
    <div class="row h-100">

        <div class="col-md-4 col-lg-3 d-flex flex-column h-100">

            <div class="p-3 mb-3 bg-white rounded shadow-sm d-flex justify-content-between align-items-center">
                <h5 class="m-0 fw-bold text-secondary">🚂 Fleet Roster</h5>
                <span class="badge bg-primary rounded-pill">@locomotives.Count</span>
            </div>

            <div class="flex-grow-1 overflow-auto mb-3 pe-2">
                @foreach (var loco in locomotives)
                {
                    bool isActive = ActiveLoco?.ID == loco.ID;
                    <div class="card mb-2 border-0 shadow-sm @(isActive ? "ring-active" : "")"
                         style="cursor: pointer; transition: transform 0.2s;"
                         @onclick="() => SelectLoco(loco)">
                        <div class="card-body p-3 d-flex justify-content-between align-items-center @(isActive ? "bg-primary text-white rounded" : "bg-white rounded")">
                            <div>
                                <h6 class="fw-bold mb-0">@loco.Name</h6>
                                <small class="@(isActive ? "text-white-50" : "text-muted")">Addr: @loco.Address</small>
                            </div>
                            <div class="text-end">
                                <span class="d-block fw-bold">@loco.Speed</span>
                                <small style="font-size:0.7em;">SPD</small>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="bg-white p-3 rounded shadow-sm mt-auto">
                <h6 class="fw-bold text-muted mb-3">Add New Locomotive</h6>
                @if (isAddingLoco)
                {
                    <div class="mb-2">
                        <input class="form-control form-control-sm mb-2" placeholder="Name (e.g. Santa Fe)" @bind="newLocoName" />
                        <input class="form-control form-control-sm mb-2" type="number" placeholder="Address (e.g. 3)" @bind="newLocoAddr" />
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-success flex-grow-1" @onclick="SaveNewLoco">Save</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => isAddingLoco = false">Cancel</button>
                        </div>
                    </div>
                }
                else
                {
                    <button class="btn btn-outline-primary w-100 border-dashed" @onclick="() => isAddingLoco = true">
                        + Add Locomotive
                    </button>
                }
            </div>
        </div>

        <div class="col-md-8 col-lg-9 h-100">
            @if (ActiveLoco != null)
            {
                <div class="card h-100 border-0 shadow-lg" style="border-radius: 20px;">
                    <div class="card-body d-flex flex-column p-5">

                        <div class="d-flex justify-content-between align-items-start mb-5">
                            <div>
                                <h1 class="display-4 fw-bold text-dark">@ActiveLoco.Name</h1>
                                <span class="badge bg-secondary fs-5">Address: @ActiveLoco.Address</span>
                                <span class="badge @(ActiveLoco.Direction == 1 ? "bg-info text-dark" : "bg-warning text-dark") fs-5 ms-2">
                                    @(ActiveLoco.Direction == 1 ? "FORWARD" : "REVERSE")
                                </span>
                            </div>
                            <button class="btn btn-danger btn-lg py-3 px-5 fw-bold shadow-sm" style="border-radius: 10px;" @onclick="EmergencyStop">
                                STOP 🛑
                            </button>
                        </div>

                        <div class="flex-grow-1 d-flex flex-column justify-content-center my-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="h4 text-muted">0</span>
                                <span class="h1 fw-bold text-primary">@ActiveLoco.Speed <small class="fs-6 text-muted">/ 127</small></span>
                                <span class="h4 text-muted">127</span>
                            </div>
                            <input type="range" class="form-range custom-range" min="0" max="127"
                                   style="height: 3rem;"
                                   value="@ActiveLoco.Speed"
                                   @onchange="@((ChangeEventArgs e) => UpdateSpeed(e))"
                                   @oninput="@((ChangeEventArgs e) => UpdateSpeed(e))" />
                        </div>

                        <div class="row mt-auto g-4">
                            <div class="col-md-3">
                                <div class="p-3 bg-light rounded-3 h-100 text-center d-flex flex-column justify-content-center">
                                    <h5 class="text-muted mb-3">Direction</h5>
                                    <div class="btn-group w-100" role="group">
                                        <button type="button" class="btn btn-lg @(ActiveLoco.Direction == 0 ? "btn-warning" : "btn-outline-secondary")"
                                                @onclick="() => SetDirection(0)">
                                            ◂ Rev
                                        </button>
                                        <button type="button" class="btn btn-lg @(ActiveLoco.Direction == 1 ? "btn-info" : "btn-outline-secondary")"
                                                @onclick="() => SetDirection(1)">
                                            Fwd ▸
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-9">
                                <div class="p-3 bg-light rounded-3 h-100 position-relative">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 class="text-muted m-0">Functions</h5>
                                        <button class="btn btn-sm btn-link text-decoration-none" @onclick="ToggleEditFunctions">
                                            @(isEditingFunctions ? "Done ✅" : "⚙️ Manage")
                                        </button>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var func in ActiveLoco.Functions.OrderBy(f => f.FIndex))
                                        {
                                            if (isEditingFunctions)
                                            {
                                                /* EDIT MODE: Show Delete badge */
                                                <div class="position-relative">
                                                    <button class="btn btn-lg btn-outline-secondary disabled" style="opacity: 0.6;">
                                                        <small class="fw-bold d-block" style="font-size: 0.6em;">F@func.FIndex</small>
                                                        @func.Name
                                                    </button>
                                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                                          style="cursor: pointer;"
                                                          @onclick="() => RemoveFunction(func)">
                                                        x
                                                    </span>
                                                </div>
                                            }
                                            else
                                            {
                                                /* NORMAL MODE: Click to toggle */
                                                <button class="btn btn-lg @(func.IsActive ? "btn-primary shadow-sm" : "btn-outline-secondary")"
                                                        @onclick="() => ToggleFunction(func)">
                                                    @func.Name
                                                </button>
                                            }
                                        }

                                        @if (isEditingFunctions)
                                        {
                                            <div class="d-inline-flex align-items-center gap-1 border rounded p-1 bg-white shadow-sm">
                                                <input type="number" class="form-control form-control-sm" style="width: 50px;" placeholder="F#" min="0" max="28" @bind="newFuncIndex" />
                                                <input type="text" class="form-control form-control-sm" style="width: 100px;" placeholder="Name" @bind="newFuncName" />
                                                <button class="btn btn-sm btn-success" @onclick="AddFunction">+</button>
                                            </div>
                                        }
                                    </div>

                                    @if (isEditingFunctions && ActiveLoco.Functions.Count == 0)
                                    {
                                        <p class="text-muted mt-2 small">Add a function (e.g., F0 "Lights") to get started.</p>
                                    }

                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
            else
            {
                <div class="h-100 d-flex flex-column justify-content-center align-items-center text-muted" style="border: 4px dashed #e0e0e0; border-radius: 20px;">
                    <h1 class="display-1">🚂</h1>
                    <h3>Select a train from the roster</h3>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .ring-active {
        border-left: 5px solid #0d6efd !important;
        transform: scale(1.02);
    }

    .border-dashed {
        border-style: dashed !important;
    }

    .custom-range::-webkit-slider-thumb {
        width: 30px;
        height: 30px;
        background: #0d6efd;
        cursor: pointer;
        margin-top: -12px;
    }

    .custom-range::-webkit-slider-runnable-track {
        height: 10px;
        background: #dee2e6;
        border-radius: 5px;
    }
</style>

@code {
    // --- Data Source ---
    List<Locomotive> locomotives = new List<Locomotive>();
    Locomotive? ActiveLoco;

    // --- UI States ---
    bool isAddingLoco = false;
    string newLocoName = "";
    int newLocoAddr = 3;

    // --- Function Editing States ---
    bool isEditingFunctions = false;
    int newFuncIndex = 0;
    string newFuncName = "";

    protected override void OnInitialized()
    {
        // Mock Data
        var loco1 = new Locomotive { ID = 1, Name = "Santa Fe #45", Address = 3 };
        loco1.Functions.Add(new LocoFunction { FIndex = 0, Name = "💡 Lights", IsActive = false });
        loco1.Functions.Add(new LocoFunction { FIndex = 1, Name = "🔔 Bell", IsActive = false });
        loco1.Functions.Add(new LocoFunction { FIndex = 2, Name = "📢 Horn", IsActive = false });

        locomotives.Add(loco1);
    }

    // --- Logic ---
    void SelectLoco(Locomotive loco)
    {
        ActiveLoco = loco;
        isEditingFunctions = false; // Reset edit mode when switching
    }

    void SaveNewLoco()
    {
        if (!string.IsNullOrWhiteSpace(newLocoName) && newLocoAddr > 0)
        {
            int newId = locomotives.Any() ? locomotives.Max(l => l.ID) + 1 : 1;
            var newLoco = new Locomotive { ID = newId, Name = newLocoName, Address = newLocoAddr };

            // Default functions
            newLoco.Functions.Add(new LocoFunction { FIndex = 0, Name = "Light" });

            locomotives.Add(newLoco);
            ActiveLoco = newLoco;

            newLocoName = ""; isAddingLoco = false;
        }
    }

    void ToggleEditFunctions()
    {
        isEditingFunctions = !isEditingFunctions;
        // Reset inputs
        newFuncIndex = 0;
        newFuncName = "";
    }

    void AddFunction()
    {
        if (ActiveLoco != null && !string.IsNullOrWhiteSpace(newFuncName))
        {
            // Prevent duplicate F-numbers
            if (!ActiveLoco.Functions.Any(f => f.FIndex == newFuncIndex))
            {
                ActiveLoco.Functions.Add(new LocoFunction
                    {
                        FIndex = newFuncIndex,
                        Name = newFuncName,
                        IsActive = false
                    });
                newFuncName = ""; // Clear name, keep index or increment?
                newFuncIndex++;   // Auto-increment for convenience
            }
        }
    }

    void RemoveFunction(LocoFunction func)
    {
        if (ActiveLoco != null)
        {
            ActiveLoco.Functions.Remove(func);
        }
    }

    // --- Driving Logic ---
    void UpdateSpeed(ChangeEventArgs e)
    {
        if (ActiveLoco != null && int.TryParse(e.Value?.ToString(), out int speed))
        {
            ActiveLoco.Speed = speed;
            TransmitData();
        }
    }

    void SetDirection(int dir)
    {
        if (ActiveLoco != null) { ActiveLoco.Direction = dir; TransmitData(); }
    }

    void ToggleFunction(LocoFunction func)
    {
        func.IsActive = !func.IsActive;
        TransmitFunction(func.FIndex, func.IsActive);
    }

    void EmergencyStop()
    {
        if (ActiveLoco != null) { ActiveLoco.Speed = 0; TransmitData(); }
    }

    // --- MQTT Stubs ---
    void TransmitData()
    {
        // TODO: Send ActiveLoco.Address, ActiveLoco.Speed, ActiveLoco.Direction
    }
    void TransmitFunction(int fIdx, bool state)
    {
        // TODO: Send ActiveLoco.Address, fIdx, state
    }

    // --- Models ---
    public class Locomotive
    {
        public int ID { get; set; }
        public string Name { get; set; } = "";
        public int Address { get; set; }
        public int Speed { get; set; }
        public int Direction { get; set; } = 1;
        public List<LocoFunction> Functions { get; set; } = new List<LocoFunction>();
    }

    public class LocoFunction
    {
        public int FIndex { get; set; } // 0-28
        public string Name { get; set; } = "Func";
        public bool IsActive { get; set; }
    }
}