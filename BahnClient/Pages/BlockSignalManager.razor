@page "/blockcontrol"
@using ModellClientLib.Models
@using ModellClientLib.Controllers
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Block & Signal Manager</PageTitle>

<div class="container-fluid vh-100 py-3" style="background-color: #f0f2f5;">
    <div class="row h-100">
        <div class="col-md-4 col-xl-3 d-flex flex-column gap-3">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold text-primary">
                    <i class="bi bi-plus-square"></i> Add Block Area
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="small text-muted fw-bold">Sensing Type</label>
                        <div class="d-flex flex-column gap-2">
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="btnradio" id="typeMag" autocomplete="off"
                                       checked="@(newBlockType == BlockType.Magnet)"
                                       @onchange="@(() => newBlockType = BlockType.Magnet)">
                                <label class="btn btn-outline-primary" for="typeMag">Magnet</label>

                                <input type="radio" class="btn-check" name="btnradio" id="typeCur" autocomplete="off"
                                       checked="@(newBlockType == BlockType.CurrentSensor)"
                                       @onchange="@(() => newBlockType = BlockType.CurrentSensor)">
                                <label class="btn btn-outline-primary" for="typeCur">Current</label>
                            </div>

                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="btnradio" id="typeSpot" autocomplete="off"
                                       checked="@(newBlockType == BlockType.OnePointCurrentSensor)"
                                       @onchange="@(() => newBlockType = BlockType.OnePointCurrentSensor)">
                                <label class="btn btn-outline-secondary" for="typeSpot">📍 Spot / Event Sensor</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="small text-muted">Controller Topic</label>
                        <input class="form-control mb-2" placeholder="e.g. esp32_main" @bind="newBlockTopic" />

                        <label class="small text-muted">Block Name</label>
                        <input class="form-control" placeholder="e.g. Station Stop Point" @bind="newBlockName" />
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-12">
                            <label class="small text-muted">@(newBlockType == BlockType.Magnet ? "Sensor A (Entry)" : "Sensor Pin")</label>
                            <input type="number" class="form-control" placeholder="GPIO Pin" @bind="newBlockPinA" />
                        </div>

                        @if (newBlockType == BlockType.Magnet)
                        {
                            <div class="col-12">
                                <label class="small text-muted">Sensor B (Exit)</label>
                                <input type="number" class="form-control" placeholder="GPIO Pin" @bind="newBlockPinB" />
                            </div>
                        }
                    </div>

                    <button class="btn btn-primary w-100" @onclick="AddBlock">
                        <i class="bi bi-save"></i> Create Block
                    </button>
                </div>
            </div>

            <div class="alert alert-info small border-0 shadow-sm">
                <i class="bi bi-info-circle-fill me-1"></i>
                <strong>Tip:</strong> Spot sensors are useful for precise stopping points (e.g., Reed switches) where direction doesn't matter.
            </div>
        </div>

        <div class="col-md-8 col-xl-9 overflow-auto">
            <h5 class="fw-bold text-secondary mb-3"><i class="bi bi-stoplights"></i> Track Blocks</h5>

            @if (Blocks.Count == 0)
            {
                <div class="text-center text-muted mt-5">
                    <i class="bi bi-train-freight display-1 opacity-25"></i>
                    <p class="mt-3">No blocks defined yet.</p>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var block in Blocks)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="card h-100 border-0 shadow-sm transition-card">
                                <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                                    <div class="d-flex align-items-center gap-2">
                                        @if (block.Type == BlockType.Magnet)
                                        {
                                            <span class="badge bg-light text-dark border">🧲 Magnet</span>
                                        }
                                        else if (block.Type == BlockType.CurrentSensor)
                                        {
                                            <span class="badge bg-light text-dark border">⚡ Current</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-primary border border-primary">📍 Spot</span>
                                        }
                                        <small class="text-muted">#@block.ID</small>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <small class="text-muted text-truncate" style="max-width: 100px;">@block.ControllerTopic</small>
                                        <button class="btn btn-sm btn-link text-danger p-0" @onclick="() => DeleteBlock(block)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <h5 class="fw-bold m-0 text-truncate" style="max-width: 180px;">@block.Name</h5>
                                            <small class="text-muted">
                                                Pin @block.PinA @(block.PinB.HasValue ? $" / {block.PinB}" : "")
                                            </small>
                                        </div>
                                        <div class="status-pill @(block.IsOccupied ? "bg-danger shadow-red animate-pulse" : "bg-success shadow-green")">
                                            @(block.IsOccupied ? (block.Type == BlockType.OnePointCurrentSensor ? "TRIGGERED" : "OCCUPIED") : "FREE")
                                        </div>
                                    </div>

                                    @if (block.Type == BlockType.Magnet)
                                    {
                                        <div class="bg-light rounded p-2 mb-3 border">
                                            <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                                <span class="small fw-bold text-secondary" style="font-size: 0.7em;">DIRECTION</span>
                                                @if (block.IsOccupied)
                                                {
                                                    <span class="badge @GetDirectionBadgeClass(block.Direction)">
                                                        @if (block.Direction == BlockDirection.Forward)
                                                        {
                                                            <span>A <i class="bi bi-arrow-right"></i> B</span>
                                                        }
                                                        else if (block.Direction == BlockDirection.Reverse)
                                                        {
                                                            <span>A <i class="bi bi-arrow-left"></i> B</span>
                                                        }
                                                        else
                                                        {
                                                            <span>Unknown</span>
                                                        }
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">-</span>
                                                }
                                            </div>

                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="small fw-bold text-secondary" style="font-size: 0.7em;">AXLE COUNT</span>
                                                <span class="fw-bold font-monospace bg-white border px-2 rounded">@block.MagnetCount</span>
                                            </div>
                                        </div>

                                        <div class="mt-auto d-flex gap-2">
                                            @if (block.IsOccupied)
                                            {
                                                <button class="btn btn-outline-warning btn-sm flex-grow-1" @onclick="() => FlipDirection(block)">
                                                    <i class="bi bi-arrow-left-right"></i> Flip
                                                </button>
                                            }
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => ResetBlock(block)">Reset</button>
                                            <button class="btn btn-outline-secondary text-danger btn-sm" @onclick="() => DeleteBlock(block)">Delete</button>

                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert @(block.IsOccupied ? "alert-warning" : "alert-light border") py-3 mb-0 small text-center flex-grow-1 d-flex align-items-center justify-content-center">
                                            @if (block.IsOccupied)
                                            {
                                                <span><i class="bi bi-lightning-charge-fill text-warning"></i> Signal Active</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No Signal</span>
                                            }
                                        </div>
                                        <div class="mt-2 text-end">
                                            <button class="btn btn-link btn-sm text-muted text-decoration-none" @onclick="() => ResetBlock(block)">Force Clear</button>
                                            <button class="btn btn-link btn-sm  text-danger" @onclick="() => DeleteBlock(block)">Delete</button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .status-pill {
        padding: 4px 12px;
        border-radius: 20px;
        color: white;
        font-weight: bold;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
    }

    .shadow-red {
        box-shadow: 0 0 10px rgba(220, 53, 69, 0.4);
    }

    .shadow-green {
        box-shadow: 0 0 10px rgba(25, 135, 84, 0.4);
    }

    .animate-pulse {
        animation: pulse-red 2s infinite;
    }

    @@keyframes pulse-red {
        0% {
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
        }

        70% {
            box-shadow: 0 0 0 6px rgba(220, 53, 69, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
        }
    }

    .transition-card {
        transition: transform 0.2s;
    }

        .transition-card:hover {
            transform: translateY(-2px);
        }
</style>

@code {
    List<BlockArea> Blocks = new List<BlockArea>();

    BlockType newBlockType = BlockType.Magnet;
    string newBlockName = "";
    string newBlockTopic = "esp32_1";
    int newBlockPinA;
    int? newBlockPinB;

    protected override void OnInitialized()
    {
        BlockController.OnDataChanged += RefreshUI;
        RefreshUI();
    }

    public void Dispose()
    {
        BlockController.OnDataChanged -= RefreshUI;
    }

    void RefreshUI()
    {
        InvokeAsync(() =>
        {
            Blocks = BlockController.GetBlocks();
            StateHasChanged();
        });
    }

    async Task AddBlock()
    {
        if (!string.IsNullOrWhiteSpace(newBlockName))
        {
            var b = new BlockArea
                {
                    Name = newBlockName,
                    ControllerTopic = newBlockTopic,
                    Type = newBlockType,
                    PinA = newBlockPinA,
                    // Only Magnet uses PinB, others use PinA only
                    PinB = (newBlockType == BlockType.Magnet) ? newBlockPinB : null
                };

            await BlockController.AddBlockAsync(b);

            newBlockName = "";
            // Keep Pins/Topic for easy sequential entry
        }
    }

    async Task FlipDirection(BlockArea b)
    {
        await BlockController.FlipDirectionAsync(b.ID);
    }

    async Task ResetBlock(BlockArea b)
    {
        await BlockController.ResetBlockAsync(b.ID);
    }

    async Task DeleteBlock(BlockArea b)
    {
        await BlockController.DeleteBlockAsync(b.ID);
    }

    string GetDirectionBadgeClass(BlockDirection dir) => dir switch
    {
        BlockDirection.Forward => "bg-info text-dark",
        BlockDirection.Reverse => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}