@page "/accessorycontrol"
@using System.Collections.Generic;
@using System.Linq;

<PageTitle>Multi-Function Control</PageTitle>

<div class="container-fluid vh-100 py-3" style="background-color: #e9ecef;">
    <div class="row h-100">

        <div class="col-md-4 col-lg-3 d-flex flex-column h-100">

            <div class="p-3 mb-3 bg-dark text-white rounded shadow-sm d-flex justify-content-between align-items-center">
                <h5 class="m-0 fw-bold"><i class="bi bi-cpu-fill me-2"></i>Decoders</h5>
                <span class="badge bg-secondary rounded-pill">@decoders.Count</span>
            </div>

            <div class="flex-grow-1 overflow-auto mb-3 pe-2">
                @foreach (var dec in decoders)
                {
                    bool isActive = ActiveDecoder?.ID == dec.ID;
                    <div class="card mb-2 border-0 shadow-sm @(isActive ? "ring-active" : "")"
                         style="cursor: pointer; transition: transform 0.2s;"
                         @onclick="() => SelectDecoder(dec)">
                        <div class="card-body p-3 @(isActive ? "bg-primary text-white rounded" : "bg-white rounded")">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <h6 class="fw-bold mb-0">@dec.Name</h6>
                                <span class="badge @(isActive ? "bg-white text-primary" : "bg-light text-dark border")">
                                    Base: @dec.BaseAddress
                                </span>
                            </div>
                            <small class="@(isActive ? "text-white-50" : "text-muted")">
                                @dec.Functions.Count(f => f.IsActive) / @dec.Functions.Count active
                            </small>
                            <div class="progress mt-2" style="height: 4px;">
                                <div class="progress-bar bg-warning" role="progressbar"
                                     style="width: @(GetActivePercent(dec))%"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="bg-white p-3 rounded shadow-sm mt-auto">
                <h6 class="fw-bold text-muted mb-3">Add Function Decoder</h6>
                @if (isAdding)
                {
                    <div class="mb-2">
                        <input class="form-control form-control-sm mb-2" placeholder="Name (e.g. Roundhouse)" @bind="newDecName" />
                        <input class="form-control form-control-sm mb-2" type="number" placeholder="Base Address (e.g. 200)" @bind="newDecAddr" />
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-success flex-grow-1" @onclick="SaveNewDecoder">Create</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => isAdding = false">Cancel</button>
                        </div>
                    </div>
                }
                else
                {
                    <button class="btn btn-outline-dark w-100 border-dashed" @onclick="() => isAdding = true">
                        + New Decoder
                    </button>
                }
            </div>
        </div>

        <div class="col-md-8 col-lg-9 h-100">
            @if (ActiveDecoder != null)
            {
                <div class="card h-100 border-0 shadow-lg bg-dark text-white" style="border-radius: 20px;">
                    <div class="card-header bg-transparent border-0 p-4 d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="fw-bold mb-0"><i class="bi bi-box-seam me-2"></i>@ActiveDecoder.Name</h2>
                            <span class="text-white-50">Base Address: @ActiveDecoder.BaseAddress</span>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-danger" @onclick="DeleteActiveDecoder">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>

                    <div class="card-body p-4 d-flex flex-column">

                        <div class="p-3 bg-secondary bg-opacity-25 rounded-3 mb-4 d-flex justify-content-between align-items-center border border-secondary">
                            <span class="fw-bold text-uppercase letter-spacing-1">Master Control</span>
                            <div class="btn-group">
                                <button class="btn btn-outline-light" @onclick="() => SetAll(false)">All Off</button>
                                <button class="btn btn-warning text-dark fw-bold" @onclick="() => SetAll(true)">All On</button>
                            </div>
                        </div>

                        <div class="flex-grow-1 overflow-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="text-white-50 m-0">Outputs / Functions</h5>
                                <button class="btn btn-sm btn-link text-decoration-none text-info" @onclick="ToggleEditMode">
                                    @(isEditing ? "Done Editing ✅" : "⚙️ Configure Outputs")
                                </button>
                            </div>

                            <div class="row g-3">
                                @foreach (var func in ActiveDecoder.Functions.OrderBy(f => f.PortIndex))
                                {
                                    <div class="col-6 col-md-4 col-lg-3">
                                        <div class="position-relative h-100">

                                            @if (isEditing)
                                            {
                                                <div class="card bg-secondary h-100 border-danger border-dashed">
                                                    <div class="card-body p-2 d-flex flex-column justify-content-center text-center">
                                                        <span class="badge bg-dark mb-1">Port @func.PortIndex</span>
                                                        <span class="fw-bold text-white mb-2">@func.Name</span>
                                                        <button class="btn btn-sm btn-danger mt-auto" @onclick="() => RemoveFunction(func)">Remove</button>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <button class="btn w-100 h-100 py-4 d-flex flex-column align-items-center justify-content-center transition-all @(func.IsActive ? "btn-light shadow-glow" : "btn-outline-secondary text-white-50")"
                                                        style="border-radius: 15px; border-width: 2px;"
                                                        @onclick="() => ToggleFunction(func)">

                                                    <i class="bi @(func.IsActive ? "bi-lightbulb-fill text-warning" : "bi-lightbulb") fs-1 mb-2"></i>
                                                    <span class="fw-bold">@func.Name</span>
                                                    <small class="text-muted" style="font-size: 0.7em;">Port @func.PortIndex</small>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (isEditing)
                                {
                                    <div class="col-6 col-md-4 col-lg-3">
                                        <div class="card bg-dark border-secondary h-100 p-3 dashed-border d-flex flex-column justify-content-center">
                                            <h6 class="text-muted text-center mb-2">Add Output</h6>
                                            <input type="number" class="form-control form-control-sm mb-1 bg-secondary text-white border-0" placeholder="Port #" @bind="newFuncPort" />
                                            <input type="text" class="form-control form-control-sm mb-2 bg-secondary text-white border-0" placeholder="Name" @bind="newFuncName" />
                                            <button class="btn btn-success btn-sm w-100" @onclick="AddFunction">Add</button>
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (ActiveDecoder.Functions.Count == 0 && !isEditing)
                            {
                                <div class="text-center text-muted mt-5">
                                    <i class="bi bi-plug fs-1"></i>
                                    <p>No outputs defined. Click "Configure Outputs" to add one.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="h-100 d-flex flex-column justify-content-center align-items-center text-muted" style="border: 4px dashed #adb5bd; border-radius: 20px;">
                    <h1 class="display-1"><i class="bi bi-hdd-rack"></i></h1>
                    <h3>Select a Multi-Function Decoder</h3>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .ring-active {
        border-left: 5px solid #0d6efd !important;
        transform: scale(1.02);
    }

    .border-dashed {
        border-style: dashed !important;
    }

    .dashed-border {
        border: 2px dashed #6c757d;
    }

    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    /* Glowing effect for active buttons */
    .shadow-glow {
        box-shadow: 0 0 15px rgba(255, 193, 7, 0.6) !important;
        border-color: #ffc107 !important;
        transform: translateY(-2px);
    }

    .transition-all {
        transition: all 0.2s ease-in-out;
    }
</style>

@code {
    // --- Data ---
    List<MultiDecoder> decoders = new List<MultiDecoder>();
    MultiDecoder? ActiveDecoder;

    // --- State ---
    bool isAdding = false;
    string newDecName = "";
    int newDecAddr = 200;

    bool isEditing = false;
    int newFuncPort = 1;
    string newFuncName = "";

    protected override void OnInitialized()
    {
        // Mock Data
        var d1 = new MultiDecoder { ID = 1, Name = "Main Station Lighting", BaseAddress = 200 };
        d1.Functions.Add(new DecoderFunction { PortIndex = 1, Name = "Ticket Hall", IsActive = true });
        d1.Functions.Add(new DecoderFunction { PortIndex = 2, Name = "Platform 1", IsActive = false });
        d1.Functions.Add(new DecoderFunction { PortIndex = 3, Name = "Platform 2", IsActive = false });
        d1.Functions.Add(new DecoderFunction { PortIndex = 4, Name = "Clock Tower", IsActive = true });

        decoders.Add(d1);
    }

    // --- Decoder CRUD ---
    void SelectDecoder(MultiDecoder d) { ActiveDecoder = d; isEditing = false; }

    void SaveNewDecoder()
    {
        if (!string.IsNullOrWhiteSpace(newDecName) && newDecAddr > 0)
        {
            int newId = decoders.Any() ? decoders.Max(d => d.ID) + 1 : 1;
            var newDec = new MultiDecoder { ID = newId, Name = newDecName, BaseAddress = newDecAddr };
            // Add a default port
            newDec.Functions.Add(new DecoderFunction { PortIndex = 1, Name = "Port 1" });

            decoders.Add(newDec);
            ActiveDecoder = newDec;
            isAdding = false; newDecName = ""; newDecAddr += 10; // Auto increment next address guess
        }
    }

    void DeleteActiveDecoder()
    {
        if (ActiveDecoder != null)
        {
            decoders.Remove(ActiveDecoder);
            ActiveDecoder = null;
        }
    }

    // --- Function/Port CRUD ---
    void ToggleEditMode()
    {
        isEditing = !isEditing;
        if (isEditing && ActiveDecoder != null)
        {
            // Guess next port number
            newFuncPort = ActiveDecoder.Functions.Any() ? ActiveDecoder.Functions.Max(f => f.PortIndex) + 1 : 1;
            newFuncName = "";
        }
    }

    void AddFunction()
    {
        if (ActiveDecoder != null && !string.IsNullOrWhiteSpace(newFuncName))
        {
            if (!ActiveDecoder.Functions.Any(f => f.PortIndex == newFuncPort))
            {
                ActiveDecoder.Functions.Add(new DecoderFunction { PortIndex = newFuncPort, Name = newFuncName });
                newFuncPort++;
                newFuncName = "";
            }
        }
    }

    void RemoveFunction(DecoderFunction func)
    {
        if (ActiveDecoder != null) ActiveDecoder.Functions.Remove(func);
    }

    // --- Control Logic ---
    void ToggleFunction(DecoderFunction func)
    {
        func.IsActive = !func.IsActive;
        Transmit(func);
    }

    void SetAll(bool state)
    {
        if (ActiveDecoder != null)
        {
            foreach (var f in ActiveDecoder.Functions)
            {
                f.IsActive = state;
                Transmit(f); // Caution: This might flood the bus if you have 20 ports. Better to send a bulk command if supported.
            }
        }
    }

    double GetActivePercent(MultiDecoder d)
    {
        if (d.Functions.Count == 0) return 0;
        return (double)d.Functions.Count(f => f.IsActive) / d.Functions.Count * 100;
    }

    // --- MQTT Stub ---
    void Transmit(DecoderFunction func)
    {
        if (ActiveDecoder == null) return;

        // TODO: Send Command
        // Logic depends on your hardware.
        // Option A: Continuous addressing (Address = Base + PortIndex - 1)
        // Option B: Loco Function style (Address = Base, Function = PortIndex)

        int finalAddress = ActiveDecoder.BaseAddress + func.PortIndex; // Example logic
                                                                       // Publish: { "address": finalAddress, "state": func.IsActive }
    }

    // --- Models ---
    public class MultiDecoder
    {
        public int ID { get; set; }
        public string Name { get; set; } = "";
        public int BaseAddress { get; set; }
        public List<DecoderFunction> Functions { get; set; } = new List<DecoderFunction>();
    }

    public class DecoderFunction
    {
        public int PortIndex { get; set; } // e.g., 1, 2, 3...
        public string Name { get; set; } = "Port";
        public bool IsActive { get; set; }
    }
}