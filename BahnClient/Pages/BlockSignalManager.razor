    // --- ACTIONS ---

    void AddBlock()
    {
        if (string.IsNullOrWhiteSpace(newBlockName)) return;

        // 1. Update Local List
        var b = new BlockArea { Name = newBlockName, PinA = newBlockPinA, PinB = newBlockPinB };
        Blocks.Add(b);

        // 2. Send MQTT Command to ESP32
        // Format matches ESP32: { "name": "...", "A": 1, "B": 2 }
        var payload = new { name = newBlockName, A = newBlockPinA, B = newBlockPinB };
        string json = JsonSerializer.Serialize(payload);
        // MqttClientSingleton.Instance.Publish("layout/control/add_block", json);

        // Reset Form
        newBlockName = ""; newBlockPinA = 0; newBlockPinB = 0;
    }

    void ResetBlock(BlockArea b)
    {
        b.MagnetCount = 0;
        b.IsOccupied = false;

        // Command ESP32 to reset logic
        var payload = new { name = b.Name };
        string json = JsonSerializer.Serialize(payload);
        // MqttClientSingleton.Instance.Publish("layout/control/reset_block", json);
    }

    void AddPoint()
    {
        if (string.IsNullOrWhiteSpace(newPointName)) return;

        var p = new SensorPoint { Name = newPointName, Pin = newPointPin };
        Points.Add(p);

        // Command ESP32
        var payload = new { name = newPointName, pin = newPointPin };
        string json = JsonSerializer.Serialize(payload);
        // MqttClientSingleton.Instance.Publish("layout/control/add_point", json);

        newPointName = ""; newPointPin = 0;
    }

    void ResetPoint(SensorPoint p)
    {
        p.IsTriggered = false;
        var payload = new { name = p.Name };
        string json = JsonSerializer.Serialize(payload);
        // MqttClientSingleton.Instance.Publish("layout/control/reset_point", json);
    }
