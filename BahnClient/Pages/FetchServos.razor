@page "/ServoList"
@using ModellClientLib.Context
@using ModellClientLib.Controllers
@using ModellClientLib.Models
@inject NavigationManager Navigation

<PageTitle>Servo Manager</PageTitle>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold"><i class="bi bi-robot"></i> Servo Manager</h1>
            <p class="text-muted">Manage and calibrate connected actuators</p>
        </div>
        <a href="/AddServo" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-lg"></i> Add New
        </a>
    </div>

    @if (servos == null)
    {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2">Loading devices...</p>
            </div>
    }
    else if (!servos.Any())
    {
            <div class="alert alert-warning text-center">
                No servos configured. Click "Add New" to get started.
            </div>
    }
    else
    {
            <div class="row g-4">
            @foreach (var servo in servos)
            {
                // Protect against divide by zero if max == min
                int range = (servo.MaxDegree - servo.MinDegree);
                int percent = range > 0 ? ((servo.degree - servo.MinDegree) * 100) / range : 0;

                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm hover-shadow transition-card">

                                <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-3 pb-0">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge bg-primary rounded-circle p-2" style="width: 32px; height: 32px; display:flex; align-items:center; justify-content:center;">
                                    @servo.iD
                                        </span>
                                        <h5 class="card-title fw-bold mb-0 text-dark">@servo.name</h5>
                                    </div>
                                    <button class="btn btn-outline-danger btn-sm border-0" title="Delete" @onclick="@(() => DeleteServo(servo.iD))">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>

                                <div class="card-body">
                                    <div class="mb-3 mt-2">
                                        <div class="d-flex justify-content-between small text-muted mb-1">
                                            <span>Min: @servo.MinDegree°</span>
                                            <span class="fw-bold text-primary">Current: @servo.degree°</span>
                                            <span>Max: @servo.MaxDegree°</span>
                                        </div>
                                        <div class="progress" style="height: 10px;">
                                            <div class="progress-bar bg-primary" role="progressbar" 
                                                 style="width: @percent%" 
                                                 aria-valuenow="@servo.degree" 
                                                 aria-valuemin="@servo.MinDegree" 
                                                 aria-valuemax="@servo.MaxDegree">
                                            </div>
                                        </div>
                                    </div>

                                    <div class="d-grid gap-2 d-flex justify-content-center">
                                        <button class="btn btn-outline-primary flex-grow-1" @onclick="@(() => UpdateServoValue(servo, servo.MinDegree))">
                                            <i class="bi bi-arrow-bar-left"></i> Set Min
                                        </button>
                                        <button class="btn btn-primary flex-grow-1" @onclick="@(() => UpdateServoValue(servo, servo.MaxDegree))">
                                            Set Max <i class="bi bi-arrow-bar-right"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="card-footer bg-light border-0 py-2">
                                    <div class="d-flex justify-content-between text-muted" style="font-size: 0.75rem;">
                                        <span><i class="bi bi-cpu"></i> Pin: @servo.pwmPinId</span>
                                        <span class="text-truncate" style="max-width: 150px;" title="@servo.topic">
                                            <i class="bi bi-wifi"></i> @servo.topic
                                        </span>
                                    </div>
                                </div>

                            </div>
                        </div>
            }
            </div>
    }
</div>

<style>
    .hover-shadow:hover {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
        transform: translateY(-2px);
    }
    .transition-card {
        transition: all 0.2s ease-in-out;
    }
</style>

@code {
    ModellDBContext context = new ModellDBContext();
    IEnumerable<Servo> servos;

    protected override void OnInitialized()
    {
        LoadServos();
    }

    void LoadServos()
    {
        servos = ServoController.GetServos();
    }

    async void UpdateServoValue(Servo servoToUpdate, int newValue)
    {
        servoToUpdate.degree = newValue;
        // The UI will update the visual bar automatically because the object ref changes
        await ServoController.UpdateServoAsync(servoToUpdate).ConfigureAwait(false);
        StateHasChanged(); // Force re-render to animate the progress bar
    }

    void DeleteServo(int servoId)
    {
        ServoController.Delete(servoId);
        LoadServos(); // Refresh list
    }
}