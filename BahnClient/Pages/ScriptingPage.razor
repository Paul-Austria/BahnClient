@page "/automation"
@using System.Collections.Generic;

<PageTitle>Automation Studio</PageTitle>

<div class="container-fluid vh-100 d-flex flex-column overflow-hidden" style="background-color: #1e1e1e; color: #d4d4d4;">

    <header class="d-flex justify-content-between align-items-center p-2 border-bottom border-secondary bg-dark">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-code-square text-warning fs-4"></i>
            <h5 class="m-0 fw-bold">Scripting Engine <small class="text-muted fs-6 ms-2">(Lua)</small></h5>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-success" @onclick="RunScript">
                <i class="bi bi-play-fill"></i> Run
            </button>
            <button class="btn btn-sm btn-danger" @onclick="StopScript">
                <i class="bi bi-stop-fill"></i> Stop
            </button>
            <button class="btn btn-sm btn-primary" @onclick="SaveScript">
                <i class="bi bi-save"></i> Save
            </button>
        </div>
    </header>

    <div class="flex-grow-1 d-flex overflow-hidden">
        
        <div class="d-flex flex-column border-end border-secondary bg-dark" style="width: 250px; min-width: 250px;">
            <div class="p-2 border-bottom border-secondary d-flex justify-content-between align-items-center">
                <span class="fw-bold small text-uppercase text-muted">My Scripts</span>
                <button class="btn btn-sm btn-link text-light p-0" @onclick="CreateNew"><i class="bi bi-plus-lg"></i></button>
            </div>
            <div class="list-group list-group-flush overflow-auto flex-grow-1">
                @foreach(var script in Scripts)
                {
                    <button class="list-group-item list-group-item-action bg-dark text-light border-secondary py-2 @(ActiveScript == script ? "active-script" : "")"
                            @onclick="() => SelectScript(script)">
                        <div class="d-flex w-100 justify-content-between align-items-center">
                            <span class="text-truncate">@script.Name</span>
                            @if(script.IsRunning)
                            {
                                <span class="spinner-grow spinner-grow-sm text-success" role="status"></span>
                            }
                        </div>
                        <small class="text-muted" style="font-size: 0.7em;">@script.LastRun</small>
                    </button>
                }
            </div>
        </div>

        <div class="flex-grow-1 d-flex flex-column position-relative">
            
            <div class="p-2 bg-dark border-bottom border-secondary d-flex align-items-center gap-3">
                <input type="text" class="form-control form-control-sm bg-secondary text-light border-0 w-auto" 
                       @bind="ActiveScript.Name" style="font-weight: bold;" />
                
                <div class="form-check form-switch text-white-50">
                    <input class="form-check-input" type="checkbox" id="autoStart" @bind="ActiveScript.AutoStart">
                    <label class="form-check-label small" for="autoStart">Run on Startup</label>
                </div>
            </div>

            <textarea class="form-control flex-grow-1 border-0 rounded-0 p-3" 
                      style="background-color: #1e1e1e; color: #dcdcaa; font-family: 'Consolas', monospace; font-size: 14px; resize: none; outline: none;"
                      spellcheck="false"
                      @bind="ActiveScript.Content"></textarea>

            <div class="border-top border-secondary bg-black" style="height: 150px; overflow-y: auto; font-family: 'Consolas', monospace; font-size: 12px;">
                <div class="sticky-top bg-secondary text-light px-2 py-1 small fw-bold d-flex justify-content-between">
                    <span><i class="bi bi-terminal"></i> Console Output</span>
                    <span class="cursor-pointer" @onclick="ClearLogs">Clear</span>
                </div>
                <div class="p-2">
                    @foreach(var log in Logs)
                    {
                        <div class="text-nowrap">
                            <span class="text-secondary">[@log.Time]</span>
                            <span class="@GetLogColor(log.Type)">@log.Message</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="border-start border-secondary bg-dark d-none d-lg-block overflow-auto" style="width: 250px; font-size: 0.85em;">
            <div class="p-2 bg-secondary text-light fw-bold small">API Reference</div>
            <div class="p-3">
                <h6 class="text-info">Trains</h6>
                <ul class="list-unstyled ps-2 mb-3">
                    <li class="mb-2">
                        <code class="text-warning">Train(id):Speed(val)</code><br>
                        <small class="text-muted">Set speed 0-127</small>
                    </li>
                    <li class="mb-2">
                        <code class="text-warning">Train(id):Stop()</code><br>
                        <small class="text-muted">Emergency stop</small>
                    </li>
                    <li class="mb-2">
                        <code class="text-warning">Train(id):Reverse()</code><br>
                        <small class="text-muted">Flip direction</small>
                    </li>
                </ul>

                <h6 class="text-info">Switches & Sensors</h6>
                <ul class="list-unstyled ps-2 mb-3">
                    <li class="mb-2">
                        <code class="text-warning">Switch(id):Throw()</code>
                    </li>
                    <li class="mb-2">
                        <code class="text-warning">Switch(id):Close()</code>
                    </li>
                    <li class="mb-2">
                        <code class="text-warning">WaitForSensor(id)</code><br>
                        <small class="text-muted">Pauses until active</small>
                    </li>
                </ul>

                <h6 class="text-info">System</h6>
                <ul class="list-unstyled ps-2 mb-3">
                    <li class="mb-2">
                        <code class="text-warning">Sleep(ms)</code><br>
                        <small class="text-muted">Pause execution</small>
                    </li>
                    <li class="mb-2">
                        <code class="text-warning">Log(msg)</code><br>
                        <small class="text-muted">Print to console</small>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</div>

<style>
    .active-script {
        background-color: #37373d !important;
        border-left: 4px solid #0d6efd !important;
    }
    textarea:focus {
        box-shadow: none !important;
        background-color: #1e1e1e !important;
        color: #dcdcaa !important;
    }
    /* Scrollbar Styling */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: #1e1e1e; }
    ::-webkit-scrollbar-thumb { background: #555; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #888; }
</style>

@code {
    // --- Models ---
    public class ScriptModel
    {
        public Guid ID { get; set; } = Guid.NewGuid();
        public string Name { get; set; } = "Untitled";
        public string Content { get; set; } = "";
        public bool AutoStart { get; set; } = false;
        public bool IsRunning { get; set; } = false;
        public string LastRun { get; set; } = "-";
    }

    public class LogEntry
    {
        public string Time { get; set; }
        public string Message { get; set; }
        public string Type { get; set; } // INFO, ERROR, WARN
    }

    // --- State ---
    List<ScriptModel> Scripts = new List<ScriptModel>();
    ScriptModel ActiveScript = new ScriptModel();
    List<LogEntry> Logs = new List<LogEntry>();

    protected override void OnInitialized()
    {
        // Add Mock Data: Shuttle Service Example
        Scripts.Add(new ScriptModel 
        { 
            Name = "Pendelzug (Shuttle)", 
            Content = @"-- Configuration
local loco_id = 3
local station_A = 101 -- Sensor ID
local station_B = 102 -- Sensor ID
local speed = 60
local pause_time = 5000 -- 5 seconds

Log('Starting Shuttle Service...')

while true do
    -- Move to Station B
    Log('Departing for Station B')
    Train(loco_id):Forward()
    Train(loco_id):Speed(speed)
    
    WaitForSensor(station_B)
    
    Train(loco_id):Stop()
    Log('Arrived at Station B. Waiting...')
    Sleep(pause_time)

    -- Return to Station A
    Log('Departing for Station A')
    Train(loco_id):Reverse()
    Train(loco_id):Speed(speed)
    
    WaitForSensor(station_A)
    
    Train(loco_id):Stop()
    Log('Arrived at Station A. Waiting...')
    Sleep(pause_time)
end"
        });

        Scripts.Add(new ScriptModel 
        { 
            Name = "Night Mode Lights", 
            Content = @"-- Turn on all street lights at 18:00
while true do
    local hour = GetSystemHour()
    if hour >= 18 or hour < 6 then
        Accessory(205):On() -- Street Lights
    else
        Accessory(205):Off()
    end
    Sleep(60000) -- Check every minute
end" 
        });

        ActiveScript = Scripts[0];
        AddLog("System initialized.", "INFO");
    }

    // --- Actions ---
    void CreateNew()
    {
        var newScript = new ScriptModel { Name = "New Script" };
        Scripts.Add(newScript);
        ActiveScript = newScript;
    }

    void SelectScript(ScriptModel s) => ActiveScript = s;

    void SaveScript() => AddLog($"Script '{ActiveScript.Name}' saved.", "INFO");

    void RunScript()
    {
        ActiveScript.IsRunning = true;
        ActiveScript.LastRun = DateTime.Now.ToShortTimeString();
        AddLog($"Started script: {ActiveScript.Name}", "INFO");
        // In real app: Send to Backend Service to execute Lua
    }

    void StopScript()
    {
        ActiveScript.IsRunning = false;
        AddLog($"Stopped script: {ActiveScript.Name}", "WARN");
        // In real app: Cancel CancellationToken for this script
    }

    void ClearLogs() => Logs.Clear();

    void AddLog(string msg, string type)
    {
        Logs.Insert(0, new LogEntry 
        { 
            Time = DateTime.Now.ToString("HH:mm:ss"), 
            Message = msg, 
            Type = type 
        });
    }

    string GetLogColor(string type) => type switch
    {
        "ERROR" => "text-danger",
        "WARN" => "text-warning",
        _ => "text-light"
    };
}