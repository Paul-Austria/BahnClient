@page "/commandcenter"
@using System.Collections.Generic;
@using System.Linq;

<PageTitle>Command Center</PageTitle>

<div class="container-fluid vh-100 d-flex flex-column overflow-hidden" style="background-color: #212529; color: white;">

    <header class="d-flex justify-content-between align-items-center p-3 border-bottom border-secondary">
        <div class="d-flex align-items-center gap-3">
            <h4 class="m-0 fw-bold"><i class="bi bi-speedometer2 text-danger"></i> Dispatch Board</h4>
            <span class="badge bg-secondary">@DashboardItems.Count active devices</span>
        </div>
        <div>
            <button class="btn btn-primary" @onclick="ToggleLibrary">
                <i class="bi bi-grid-3x3-gap-fill"></i> Add / Remove Devices
            </button>
        </div>
    </header>

    <div class="flex-grow-1 overflow-auto p-3">
        @if (DashboardItems.Count == 0)
        {
            <div class="d-flex flex-column align-items-center justify-content-center h-75 text-muted">
                <i class="bi bi-layout-wtf display-1 mb-3"></i>
                <h3>Your board is empty.</h3>
                <p>Click "Add / Remove Devices" to pin trains or switches here.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var item in DashboardItems.Where(i => i.Type == ItemType.Train))
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="card bg-dark border-secondary h-100 shadow-lg">
                            <div class="card-header border-secondary d-flex justify-content-between align-items-center py-2">
                                <div>
                                    <i class="bi bi-train-front text-primary me-2"></i>
                                    <span class="fw-bold">@item.Name</span>
                                    <span class="badge bg-black text-white-50 ms-2">#@item.Address</span>
                                </div>
                                <button class="btn btn-sm text-secondary" @onclick="() => Unpin(item)"><i class="bi bi-x-lg"></i></button>
                            </div>
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <button class="btn btn-sm @(item.Direction == 0 ? "btn-warning" : "btn-outline-secondary")" @onclick="() => SetDir(item, 0)">Rev</button>

                                    <div class="flex-grow-1">
                                        <input type="range" class="form-range custom-range" min="0" max="127"
                                               value="@item.Speed"
                                               @oninput="@((ChangeEventArgs e) => UpdateSpeed(item, e))" />
                                    </div>

                                    <button class="btn btn-sm @(item.Direction == 1 ? "btn-info" : "btn-outline-secondary")" @onclick="() => SetDir(item, 1)">Fwd</button>

                                    <button class="btn btn-danger btn-sm fw-bold" @onclick="() => Stop(item)">STOP</button>
                                </div>
                                <div class="text-center text-primary fw-bold small mb-3">Speed: @item.Speed / 127</div>

                                <div class="d-flex gap-2 justify-content-center">
                                    <button class="btn btn-sm flex-grow-1 @(item.FuncState[0] ? "btn-warning text-dark" : "btn-outline-secondary")"
                                            @onclick="() => ToggleFunc(item, 0)">
                                        💡 Light
                                    </button>
                                    <button class="btn btn-sm flex-grow-1 @(item.FuncState[1] ? "btn-primary" : "btn-outline-secondary")"
                                            @onclick="() => ToggleFunc(item, 1)">
                                        🔔 Bell
                                    </button>
                                    <button class="btn btn-sm flex-grow-1 @(item.FuncState[2] ? "btn-primary" : "btn-outline-secondary")"
                                            @onclick="() => ToggleFunc(item, 2)">
                                        📢 Horn
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @foreach (var item in DashboardItems.Where(i => i.Type == ItemType.Accessory))
                {
                    <div class="col-md-3 col-xl-2">
                        <div class="card bg-dark border-secondary h-100">
                            <div class="card-header border-secondary py-1 d-flex justify-content-between">
                                <small class="text-muted text-truncate">@item.Name</small>
                                <i class="bi bi-x text-secondary cursor-pointer" @onclick="() => Unpin(item)"></i>
                            </div>
                            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                                <button class="btn btn-lg w-100 py-3 mb-2 transition-all @(item.State == 1 ? "btn-success shadow-glow" : "btn-outline-secondary")"
                                        @onclick="() => ToggleAcc(item)">
                                    <i class="bi @(item.State == 1 ? "bi-check-circle-fill" : "bi-circle") fs-2 d-block"></i>
                                    <span class="small fw-bold">@(item.State == 1 ? "ON / THROWN" : "OFF / CLOSED")</span>
                                </button>
                                <small class="text-white-50">Addr: @item.Address</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @if (showLibrary)
    {
        <div class="position-absolute top-0 end-0 h-100 bg-white text-dark shadow-lg p-0 d-flex flex-column"
             style="width: 350px; z-index: 1050; transition: transform 0.3s ease;">

            <div class="p-3 bg-light border-bottom d-flex justify-content-between align-items-center">
                <h5 class="m-0"><i class="bi bi-collection"></i> Device Library</h5>
                <button class="btn-close" @onclick="ToggleLibrary"></button>
            </div>

            <div class="flex-grow-1 overflow-auto p-3">
                <h6 class="fw-bold text-muted mb-2">Locomotives</h6>
                @foreach (var t in AllTrains)
                {
                    <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                        <span>@t.Name <small class="text-muted">(#@t.Address)</small></span>
                        <button class="btn btn-sm @(IsPinned(t.ID, ItemType.Train) ? "btn-secondary disabled" : "btn-outline-primary")"
                                @onclick="() => PinItem(t.ID, ItemType.Train)">
                            @(IsPinned(t.ID, ItemType.Train) ? "Pinned" : "Add")
                        </button>
                    </div>
                }

                <h6 class="fw-bold text-muted mt-4 mb-2">Accessories</h6>
                @foreach (var a in AllAccessories)
                {
                    <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                        <span>@a.Name <small class="text-muted">(#@a.Address)</small></span>
                        <button class="btn btn-sm @(IsPinned(a.ID, ItemType.Accessory) ? "btn-secondary disabled" : "btn-outline-success")"
                                @onclick="() => PinItem(a.ID, ItemType.Accessory)">
                            @(IsPinned(a.ID, ItemType.Accessory) ? "Pinned" : "Add")
                        </button>
                    </div>
                }
            </div>
        </div>
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-black bg-opacity-50"
             style="z-index: 1040;" @onclick="ToggleLibrary"></div>
    }

</div>

<style>
    .custom-range::-webkit-slider-thumb {
        background: #0d6efd;
        cursor: pointer;
    }

    .custom-range::-webkit-slider-runnable-track {
        background: #495057;
    }

    .shadow-glow {
        box-shadow: 0 0 15px rgba(25, 135, 84, 0.4);
    }

    .cursor-pointer {
        cursor: pointer;
    }
</style>

@code {
    // --- Unified Model for Dashboard ---
    public enum ItemType { Train, Accessory }

    public class DashboardItem
    {
        public int ID { get; set; }
        public ItemType Type { get; set; }
        public string Name { get; set; } = "";
        public int Address { get; set; }

        // Train Specific
        public int Speed { get; set; }
        public int Direction { get; set; }
        public Dictionary<int, bool> FuncState { get; set; } = new Dictionary<int, bool> { { 0, false }, { 1, false }, { 2, false } };

        // Accessory Specific
        public int State { get; set; } // 0/1
    }

    // --- State ---
    List<DashboardItem> DashboardItems = new List<DashboardItem>();
    bool showLibrary = false;

    // --- Mock Database ---
    List<DashboardItem> AllTrains = new List<DashboardItem>
    {
        new DashboardItem { ID=1, Type=ItemType.Train, Name="Santa Fe #45", Address=3 },
        new DashboardItem { ID=2, Type=ItemType.Train, Name="Union Pacific", Address=88 },
        new DashboardItem { ID=3, Type=ItemType.Train, Name="Flying Scotsman", Address=101 }
    };

    List<DashboardItem> AllAccessories = new List<DashboardItem>
    {
        new DashboardItem { ID=10, Type=ItemType.Accessory, Name="Main Switch", Address=200 },
        new DashboardItem { ID=11, Type=ItemType.Accessory, Name="Siding Signal", Address=201 },
        new DashboardItem { ID=12, Type=ItemType.Accessory, Name="Street Lights", Address=205 }
    };

    // --- Logic ---
    void ToggleLibrary() => showLibrary = !showLibrary;

    bool IsPinned(int id, ItemType type)
    {
        return DashboardItems.Any(i => i.ID == id && i.Type == type);
    }

    void PinItem(int id, ItemType type)
    {
        var source = type == ItemType.Train ? AllTrains : AllAccessories;
        var item = source.FirstOrDefault(x => x.ID == id);

        if (item != null && !IsPinned(id, type))
        {
            // Clone or add ref. For mock, just add ref.
            DashboardItems.Add(item);
        }
    }

    void Unpin(DashboardItem item)
    {
        DashboardItems.Remove(item);
    }

    // --- Train Controls ---
    void UpdateSpeed(DashboardItem t, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int s)) { t.Speed = s; Transmit(t); }
    }

    void SetDir(DashboardItem t, int d) { t.Direction = d; Transmit(t); }
    void Stop(DashboardItem t) { t.Speed = 0; Transmit(t); }
    void ToggleFunc(DashboardItem t, int f)
    {
        t.FuncState[f] = !t.FuncState[f];
        // Transmit Func (TODO)
    }

    // --- Accessory Controls ---
    void ToggleAcc(DashboardItem a)
    {
        a.State = a.State == 0 ? 1 : 0;
        Transmit(a);
    }

    void Transmit(DashboardItem item)
    {
        // TODO: Send MQTT
        // if(item.Type == Train) -> <t addr speed dir>
        // if(item.Type == Accessory) -> <a addr state>
    }
}